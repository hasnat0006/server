import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.naive_bayes import GaussianNB
from sklearn.metrics import confusion_matrix, accuracy_score, precision_score, recall_score, f1_score
from sklearn.preprocessing import StandardScaler

# ==========================================
# 1. Data Collection and Preparation
# ==========================================
# Loading provided datasets [cite: 25, 71]
water_df = pd.read_csv('water_quality_samples.csv')
flow_df = pd.read_csv('bangladesh_river_flow_2005_2024.csv')

# Preprocessing: Checking for missing values [cite: 28]
print(f"Missing values in water data: {water_df.isnull().sum().sum()}")

# ==========================================
# 2. Part B: Bayes' Theorem Calculation
# ==========================================
def calculate_manual_bayes(df):
    """
    Manual calculation example for Part B [cite: 32, 64, 73]
    Scenario: P(Contaminated | Flow < 40, Turbidity > 30, pH <= 6.5)
    """
    total = len(df)
    
    # Priors [cite: 36]
    p_yes = len(df[df['Contaminated(1=yes,0=no)'] == 1]) / total
    
    # Evidence (Joint probability of conditions)
    evidence_mask = (df['FlowRate_m3s'] < 40) & (df['Turbidity_NTU'] > 30) & (df['pH'] <= 6.5)
    p_evidence = len(df[evidence_mask]) / total
    
    # Likelihood: P(Evidence | Yes) [cite: 38]
    p_evidence_given_yes = len(df[evidence_mask & (df['Contaminated(1=yes,0=no)'] == 1)]) / len(df[df['Contaminated(1=yes,0=no)'] == 1])
    
    # Posterior [cite: 40]
    p_yes_given_evidence = (p_evidence_given_yes * p_yes) / p_evidence
    
    return p_yes, p_evidence_given_yes, p_yes_given_evidence

prior, likelihood, posterior = calculate_manual_bayes(water_df)
print(f"--- Bayes Calculation Example ---")
print(f"Prior P(Contaminated): {prior:.2f}")
print(f"Likelihood P(Low Flow, High Turb, Low pH | Contaminated): {likelihood:.2f}")
print(f"Posterior P(Contaminated | Evidence): {posterior:.2f}")

# ==========================================
# 3. Part C: Naive Bayes Implementation
# ==========================================
# Features and Target [cite: 20, 26]
X = water_df.drop(columns=['Contaminated(1=yes,0=no)'])
y = water_df['Contaminated(1=yes,0=no)']

# 70/30 Split [cite: 43]
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.30, random_state=42)

# Scaling [cite: 30]
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

# Gaussian NB for continuous features [cite: 45, 74]
nb_model = GaussianNB()
nb_model.fit(X_train_scaled, y_train)
y_pred = nb_model.predict(X_test_scaled)

# Evaluation [cite: 50, 51, 65]
print(f"\n--- Naive Bayes Metrics ---")
print(f"Accuracy: {accuracy_score(y_test, y_pred):.4f}")
print(f"F1-Score: {f1_score(y_test, y_pred):.4f}")
print("Confusion Matrix:")
print(confusion_matrix(y_test, y_pred))

# ==========================================
# 4. Part D: Analysis for DST Reasoning
# ==========================================
def dst_reasoning_example():
    """
    Simulation for Part D Task 5 & 6 [cite: 60, 75]
    Combining evidence from Flow sensor and Turbidity sensor.
    """
    # Mass assignments: {Contaminated, Safe, Uncertain}
    # m1 (Flow Sensor): High belief it's safe
    m1 = {'C': 0.1, 'S': 0.7, 'U': 0.2}
    
    # m2 (Turbidity Sensor): Conflicting belief (High Turbidity)
    m2 = {'C': 0.6, 'S': 0.2, 'U': 0.2}
    
    # DST allows us to see how belief shifts when sensors disagree
    print(f"\n--- DST Reasoning Analysis ---")
    print(f"Flow Sensor Mass (m1): {m1}")
    print(f"Turbidity Sensor Mass (m2): {m2}")
    print("DST combines these to find a 'Belief' range, unlike Naive Bayes' single point.")

dst_reasoning_example()